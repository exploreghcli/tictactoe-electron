{
  "name": "tictactoe-electron",
  "version": "0.1.0",
  "description": "Simple Tic Tac Toe desktop app built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.5.0",
    "electron-packager": "^17.1.0"
  },
  "build": {
    "appId": "com.explo.tictactoe",
    "productName": "TicTacToe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
